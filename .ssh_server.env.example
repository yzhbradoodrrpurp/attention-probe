# Local-only SSH and remote workspace template.
# Copy to .ssh_server.env and fill real values locally. Do not commit real values.

SSH_REMOTE_USER=your_user
SSH_REMOTE_HOST=your_host
SSH_REMOTE_PORT=22
SSH_REMOTE_CODE_DIR=/absolute/remote/path/attention

# Optional remote paths used by scripts and agent rules.
SSH_REMOTE_RESULTS_DIR=/absolute/remote/path/results

# Optional whitespace-separated SSH options.
SSH_REMOTE_SSH_OPTIONS="-o StrictHostKeyChecking=accept-new"

# Optional. Prefer interactive auth or key-based auth when available.
# SSH_REMOTE_PASSWORD=
